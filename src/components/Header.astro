---
// types
export interface Props {
  title?: string;
  showNav: boolean;
}

// props
const { title, showNav } = Astro.props;

import { Icon } from "astro-icon/components";
import ThemeToggle from "./ThemeToggle.astro";
import Tooltip from "./Tooltip.astro";
// data
import { socials, rootNav } from "src/constants";

const pathName = Astro.url.pathname;
---

<header aria-label="header">
  <div class="header-container">
    {
      showNav && (
        <a href="/" class="logo-link">
          <img src="/favicon.svg" alt="Logo" class="logo" />
        </a>
      )
    }
    {title && <h1>{title}</h1>}
    {
      showNav && (
        <div class="nav-container">
          <nav aria-label="main navigation" class="desktop-nav">
            {rootNav.map((navItem) => (
              <a
                href={navItem.path}
                data-astro-prefetch="viewport"
                class={pathName === navItem.path ? "active" : ""}
              >
                {navItem.title}
              </a>
            ))}
            <a
              class="social"
              href={`https://github.com/${socials.githubUsername}`}
              target="_blank"
            >
              <Icon name={"simple-icons:github"} size={20} />
            </a>
          </nav>
          <ThemeToggle />
          <div id="menu-btn" class="mobile-menu-btn">
            <Icon name="lucide:menu" size={24} />
          </div>
        </div>
      )
    }
  </div>
</header>

<!-- Mobile navigation -->
{
  showNav && (
    <div id="mobile-overlay" class="mobile-overlay">
      <div id="close-btn" aria-label="Close mobile menu" class="close-btn">
        <Icon name="lucide:x" size={24} />
      </div>

      <nav class="mobile-nav">
        {rootNav.map((navItem) => (
          <a href={navItem.path}>{navItem.title}</a>
        ))}
        <div class="mobile-socials">
          <a
            href={`https://github.com/${socials.githubUsername}`}
            target="_blank"
            aria-label="GitHub"
          >
            <Icon name="simple-icons:github" size={20} />
          </a>
          <a href={socials.mastodon} target="_blank" aria-label="Mastodon">
            <Icon name="simple-icons:mastodon" size={20} />
          </a>
          <a
            href={`https://linkedin.com/${socials.linkedin}`}
            target="_blank"
            aria-label="Linkedin"
          >
            <Icon name="simple-icons:linkedin" size={20} />
          </a>
          <Tooltip text="Click to copy email">
            <button
              class="header-copy-email"
              data-email={socials.email}
              data-success="Copied!"
              aria-label="Copy email address"
            >
              <Icon name="lucide:mail" size={20} class="icon-mail" />
              <Icon name="lucide:check" size={20} class="icon-check" />
            </button>
          </Tooltip>
        </div>
      </nav>
    </div>
  )
}

<script>
  const menuBtn = document.getElementById("menu-btn");
  const closeBtn = document.getElementById("close-btn");
  const overlay = document.getElementById("mobile-overlay");

  overlay?.classList.remove("is-open");

  function toggleMenu() {
    if (overlay) {
      // Toggle is-open class instead of hidden
      overlay.classList.toggle("is-open");

      // Handle body scroll
      document.body.style.overflow = overlay.classList.contains("is-open")
        ? "hidden"
        : "";
    }
  }

  menuBtn?.addEventListener("click", toggleMenu);
  closeBtn?.addEventListener("click", toggleMenu);

  // Copy email
  const copyBtn =
    document.querySelector<HTMLButtonElement>(".header-copy-email");
  let copyTimeout: ReturnType<typeof setTimeout> | null = null;

  copyBtn?.addEventListener("click", async () => {
    const email = copyBtn.dataset.email!;
    const wrapper = copyBtn.closest<HTMLElement>(".tooltip-wrapper")!;
    const tooltip = wrapper.querySelector<HTMLElement>(".tooltip-text")!;

    await navigator.clipboard.writeText(email);

    if (copyTimeout) clearTimeout(copyTimeout);

    copyBtn.classList.add("copied");
    wrapper.classList.add("show-tooltip", "tooltip-success");
    tooltip.textContent = copyBtn.dataset.success!;

    copyTimeout = setTimeout(() => {
      copyBtn.classList.remove("copied");
      wrapper.classList.remove("show-tooltip", "tooltip-success");
      tooltip.textContent = "Click to copy email";
      copyTimeout = null;
    }, 2000);
  });
</script>

<style>
  .header-container {
    width: min(var(--max-width), 100%);
    padding: 1.25rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .home {
    height: 24px;
    width: 24px;
    background-color: var(--accent);
    border-radius: 6px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
    user-select: none;
  }

  .logo-link:hover {
    opacity: 0.8;
  }

  .logo {
    height: 32px;
    width: 32px;
    display: block;
    border: none;
  }

  .nav-container {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  nav a.active {
    color: var(--text);
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .social {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Mobile Menu Styles */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
  }

  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: var(--bg);
    z-index: 2000;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.5rem;

    transform: translateX(100%);
    transition:
      transform 0.3s ease-out,
      visibility 0.4s,
      opacity 0.2s;
    opacity: 0;
    visibility: hidden;
  }

  .mobile-overlay.is-open {
    transform: translateX(0);
    visibility: visible;
    opacity: 1;
  }

  .close-btn {
    position: absolute;
    top: 1.5rem;
    right: 1rem;
    cursor: pointer;
    color: var(--text);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 1.2rem;
    color: var(--text);
  }

  .mobile-socials {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .mobile-socials a,
  .header-copy-email {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
  }

  .header-copy-email {
    all: unset;
    cursor: pointer;
    color: inherit;
  }

  .header-copy-email .icon-check {
    display: none;
    color: #10b981;
  }

  .header-copy-email.copied .icon-mail {
    display: none;
  }

  .header-copy-email.copied .icon-check {
    display: block;
  }

  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>
