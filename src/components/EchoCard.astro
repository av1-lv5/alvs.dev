---
import { Icon } from "astro-icon/components";

interface Props {
  line: string;
}
const { line } = Astro.props;
---

<figure
  class="echo-card"
  tabindex="0"
  role="button"
  aria-label={`Copy: ${line}`}
>
  <p class="echo-text">{line}</p>
  <div class="echo-action" aria-hidden="true">
    <Icon class="icon icon-copy" name="lucide:copy" size={13} />
    <Icon class="icon icon-check" name="lucide:check" size={13} />
  </div>
</figure>

<style>
  .echo-card {
    position: relative;
    margin: 0;
    padding: 1.125rem 2.75rem 1.125rem 1.25rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    overflow: hidden;
    cursor: pointer;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition:
      transform 180ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 180ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 180ms ease,
      background 180ms ease;
    animation: echo-in 350ms cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  .echo-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2.5px;
    background: var(--accent);
    border-radius: 0 2px 2px 0;
    opacity: 0;
    transform: scaleY(0.4);
    transform-origin: center;
    transition:
      opacity 180ms ease,
      transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .echo-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    transform: translateY(-1px);
    box-shadow: 0 4px 16px -6px rgba(0, 0, 0, 0.12);
  }

  .echo-card:hover::before {
    opacity: 0.5;
    transform: scaleY(1);
  }

  .echo-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .echo-card.is-copied::before {
    opacity: 0.5;
    transform: scaleY(1);
  }

  .echo-text {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-muted);
    letter-spacing: -0.01em;
    margin: 0;
    font-weight: 400;
    font-style: italic;
  }

  .echo-action {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 5px;
    color: var(--text-light);
    opacity: 0;
    transition:
      opacity 150ms ease,
      color 150ms ease;
  }

  .echo-card:hover .echo-action {
    opacity: 0.6;
  }

  .echo-card.is-copied .echo-action {
    opacity: 1;
    color: var(--text-light);
  }

  .echo-card.is-reset .echo-action {
    opacity: 0 !important;
    transition: opacity 150ms ease;
  }

  .icon {
    position: absolute;
    inset: 0;
    margin: auto;
    transition:
      opacity 150ms ease,
      transform 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .icon-copy {
    opacity: 1;
    transform: scale(1);
  }

  .icon-check {
    opacity: 0;
    transform: scale(0.6);
  }

  .echo-card.is-copied .icon-copy {
    opacity: 0;
    transform: scale(0.6);
  }

  .echo-card.is-copied .icon-check {
    opacity: 1;
    transform: scale(1);
  }

  @keyframes echo-in {
    from {
      opacity: 0;
      transform: translateY(5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .echo-card,
    .echo-card::before,
    .echo-action,
    .icon {
      animation: none;
      transition: none;
    }
  }
</style>
