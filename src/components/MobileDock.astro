---
// Experimental floating bottom nav for mobile.
// Replaces the header hamburger nav + footer on small screens.
// Once approved, fold this into Header/Footer and delete this file.

import { Icon } from "astro-icon/components";
import { getSitePages } from "@utils/pageSearch";

const pathName = Astro.url.pathname;

// Progressive blur behind the dock: each layer fades in and out (trapezoid
// mask) over a band of the fade zone, with blur strength doubling per
// layer. Stacking several soft layers (rather than one hard-edged blur)
// is what makes the transition read as a gradient instead of a blur block.
const blurLayers = [32, 24, 16, 8, 4, 2, 1, 0.5];

function maskForLayer(index: number, total: number) {
  const step = 100 / total;
  const start = Math.max(0, (index - 1) * step);
  const rampIn = index * step;
  const rampOut = (index + 1) * step;
  const end = Math.min(100, (index + 2) * step);

  if (index === 0) {
    return `linear-gradient(to top, black 0%, black ${rampOut}%, transparent ${end}%)`;
  }
  if (index === total - 1) {
    return `linear-gradient(to top, transparent ${start}%, black ${rampIn}%, black 100%)`;
  }
  return `linear-gradient(to top, transparent ${start}%, black ${rampIn}%, black ${rampOut}%, transparent ${end}%)`;
}

const pages = getSitePages();
---

<div class="dock-fade" aria-hidden="true">
  {
    blurLayers.map((blur, i) => {
      const mask = maskForLayer(i, blurLayers.length);
      return (
        <span
          style={`backdrop-filter: blur(${blur}px); -webkit-backdrop-filter: blur(${blur}px); mask-image: ${mask}; -webkit-mask-image: ${mask};`}
        />
      );
    })
  }
</div>

<div class="dock-scrim" id="dock-scrim"></div>

<div class="dock" id="dock" data-expanded="false">
  <div
    class="dock-panel"
    id="dock-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Search pages"
    inert
  >
    <div class="dock-panel-scroll" id="dock-panel-scroll">
      <div class="dock-results" id="dock-results"></div>
      <p class="dock-empty" id="dock-empty" hidden>No pages match that.</p>
    </div>
    <p class="sr-only" id="dock-status" role="status" aria-live="polite"></p>
    <div class="dock-panel-fade" id="dock-panel-fade" aria-hidden="true"></div>
  </div>

  <div class="dock-bar">
    <a
      href="/"
      class="dock-icon-btn dock-logo"
      data-role="collapsed"
      aria-label="Home"
    >
      <img src="/favicon.svg" alt="" class="dock-logo-img" />
    </a>

    <div class="dock-actions" data-role="collapsed">
      <a
        href="/projects/"
        class={`dock-icon-btn ${pathName.startsWith("/projects") ? "active" : ""}`}
        aria-label="Projects"
      >
        <Icon name="lucide:code-2" size={20} />
      </a>
      <a
        href="/connect/"
        class={`dock-icon-btn ${pathName === "/connect/" ? "active" : ""}`}
        aria-label="Connect"
      >
        <Icon name="lucide:at-sign" size={20} />
      </a>
      <button
        type="button"
        class="dock-icon-btn"
        id="dock-search-btn"
        aria-label="Search"
        aria-expanded="false"
      >
        <Icon name="lucide:search" size={20} />
      </button>
    </div>

    <button
      type="button"
      class="dock-icon-btn"
      id="dock-back-btn"
      data-role="expanded"
      aria-label="Close search"
    >
      <Icon name="lucide:arrow-left" size={20} />
    </button>
    <input
      type="search"
      id="dock-search-input"
      data-role="expanded"
      class="dock-input"
      placeholder="Search pages..."
      aria-label="Search pages"
      autocomplete="off"
      enterkeyhint="search"
      inputmode="search"
    />
  </div>
</div>

<script>
  import {
    rankPages,
    debounce,
    groupByCategory,
    createResultLink,
    type SitePage,
  } from "@utils/pageSearch";

  const dock = document.getElementById("dock");
  const panel = document.getElementById("dock-panel");
  const scrim = document.getElementById("dock-scrim");
  const panelScroll = document.getElementById("dock-panel-scroll");
  const panelFade = document.getElementById("dock-panel-fade");
  const resultsEl = document.getElementById("dock-results");
  const emptyEl = document.getElementById("dock-empty");
  const statusEl = document.getElementById("dock-status");
  const searchBtn = document.getElementById("dock-search-btn");
  const backBtn = document.getElementById("dock-back-btn");
  const input = document.getElementById(
    "dock-search-input",
  ) as HTMLInputElement | null;

  const makeResultLink = (entry: SitePage) => createResultLink(entry, "dock");

  const pages: SitePage[] = JSON.parse(
    document.getElementById("dock-data")?.textContent || "[]",
  );

  function renderList(items: SitePage[]) {
    if (!resultsEl) return;
    resultsEl.classList.remove("is-flat");
    resultsEl.innerHTML = "";
    const groups = groupByCategory(items);
    for (const [category, entries] of groups) {
      const section = document.createElement("div");
      section.className = "dock-group";

      const heading = document.createElement("h3");
      heading.className = "dock-group-title";
      heading.textContent = category;
      section.appendChild(heading);

      for (const entry of entries) {
        section.appendChild(makeResultLink(entry));
      }
      resultsEl.appendChild(section);
    }
  }

  function renderFlatList(items: SitePage[]) {
    if (!resultsEl) return;
    resultsEl.classList.add("is-flat");
    resultsEl.innerHTML = "";
    for (const entry of items) {
      resultsEl.appendChild(makeResultLink(entry));
    }
  }

  function updateFadeVisibility() {
    if (!panelScroll || !panelFade) return;
    const atBottom =
      panelScroll.scrollHeight -
        panelScroll.scrollTop -
        panelScroll.clientHeight <
      4;
    panelFade.style.opacity = atBottom ? "0" : "1";
  }

  function update(query: string) {
    const trimmed = query.trim();

    if (!trimmed) {
      if (emptyEl) emptyEl.hidden = true;
      renderList(pages);
      if (panelScroll) panelScroll.scrollTop = 0;
      if (statusEl) statusEl.textContent = `${pages.length} pages`;
    } else {
      // Fuzzy-ranked: title matches always outrank description matches,
      // which always outrank category matches (see rankPages).
      const ranked = rankPages(pages, trimmed);
      if (emptyEl) emptyEl.hidden = ranked.length > 0;
      // The search input sits at the bottom of the screen, so the best
      // match should land closest to it — render weakest-first so the
      // top match ends up last (nearest the input), and default-scroll
      // to the bottom to reveal it without the user having to scroll up.
      renderFlatList([...ranked].reverse());
      if (panelScroll) panelScroll.scrollTop = panelScroll.scrollHeight;
      if (statusEl)
        statusEl.textContent = ranked.length
          ? `${ranked.length} result${ranked.length === 1 ? "" : "s"}`
          : "No pages match that.";
    }

    requestAnimationFrame(updateFadeVisibility);
  }

  const debouncedUpdate = debounce(update, 200);

  // On mobile, opening the keyboard shrinks the visual viewport but the
  // layout viewport (which fixed-position elements are anchored to) stays
  // the same size — so a static bottom offset + 60vh panel height end up
  // computed against the pre-keyboard screen and get pushed off-screen.
  // Track the visual viewport directly and feed it back in as CSS vars.
  function updateViewportOffset() {
    const vv = window.visualViewport;
    if (!dock || !vv) return;
    const keyboardInset = window.innerHeight - vv.height - vv.offsetTop;
    dock.style.setProperty(
      "--dock-bottom-offset",
      `${Math.max(0, keyboardInset)}px`,
    );
    dock.style.setProperty("--dock-max-panel-height", `${vv.height * 0.6}px`);
  }

  function expand() {
    dock?.setAttribute("data-expanded", "true");
    scrim?.setAttribute("data-visible", "true");
    searchBtn?.setAttribute("aria-expanded", "true");
    panel?.removeAttribute("inert");
    update("");
    document.body.style.overflow = "hidden";
    updateViewportOffset();
    requestAnimationFrame(() => input?.focus());
  }

  function collapse() {
    dock?.setAttribute("data-expanded", "false");
    scrim?.setAttribute("data-visible", "false");
    searchBtn?.setAttribute("aria-expanded", "false");
    panel?.setAttribute("inert", "");
    document.body.style.overflow = "";
    if (input) input.value = "";
    // Return focus to the control that opened the panel, rather than
    // letting it fall to <body> when the back button becomes display:none.
    searchBtn?.focus();
  }

  // The expanded dock is a modal, so keep Tab focus inside it.
  function trapFocus(e: KeyboardEvent) {
    if (e.key !== "Tab" || dock?.getAttribute("data-expanded") !== "true") {
      return;
    }
    const focusable = dock?.querySelectorAll<HTMLElement>(
      'a[href], button:not([disabled]), input, [tabindex]:not([tabindex="-1"])',
    );
    if (!focusable || focusable.length === 0) return;
    const list = Array.from(focusable).filter(
      (el) => el.offsetParent !== null || el === document.activeElement,
    );
    const first = list[0];
    const last = list[list.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  window.visualViewport?.addEventListener("resize", updateViewportOffset);
  window.visualViewport?.addEventListener("scroll", updateViewportOffset);

  searchBtn?.addEventListener("click", expand);
  backBtn?.addEventListener("click", collapse);
  scrim?.addEventListener("click", collapse);
  input?.addEventListener("input", (e) =>
    debouncedUpdate((e.target as HTMLInputElement).value),
  );
  panelScroll?.addEventListener("scroll", updateFadeVisibility);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && dock?.getAttribute("data-expanded") === "true") {
      collapse();
    } else if (e.key === "Tab") {
      trapFocus(e);
    }
  });
</script>

<script
  id="dock-data"
  type="application/json"
  set:html={JSON.stringify(pages)}
/>

<style>
  .dock,
  .dock-scrim,
  .dock-fade {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .dock-panel,
    .dock-scrim,
    .dock-panel-fade {
      transition: none;
    }

    :global(.dock-result-link:active) {
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .dock-fade {
      display: block;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      height: 150px;
      z-index: 1450;
      pointer-events: none;
    }

    .dock-fade::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
      opacity: 0.75;
    }

    .dock-fade span {
      position: absolute;
      inset: 0;
    }

    .dock-scrim {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 1400;
      background: rgba(0, 0, 0, 0.25);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
    }

    .dock-scrim[data-visible="true"] {
      opacity: 1;
      pointer-events: auto;
    }

    .dock {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      position: fixed;
      left: 50%;
      bottom: calc(
        1rem + env(safe-area-inset-bottom) + var(--dock-bottom-offset, 0px)
      );
      transform: translateX(-50%);
      width: min(420px, calc(100vw - 2rem));
      z-index: 1500;
    }

    :global(header),
    :global(footer) {
      display: none !important;
    }

    :global(main) {
      min-height: calc(100vh - 96px);
      padding-bottom: 5rem;
    }
  }

  .dock-panel {
    position: relative;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    margin-bottom: 0;
    background: var(--bg-translucent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: 20px;
    transition:
      max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease,
      margin 0.3s ease;
  }

  .dock[data-expanded="true"] .dock-panel {
    max-height: var(--dock-max-panel-height, 60vh);
    opacity: 1;
    margin-bottom: 0.5rem;
  }

  .dock-panel-scroll {
    max-height: var(--dock-max-panel-height, 60vh);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .dock-panel-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 40px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    background: linear-gradient(
      to top,
      var(--bg-translucent) 0%,
      transparent 100%
    );
  }

  .dock-results {
    padding: 0 0.75rem 0.5rem 0.75rem;
  }

  .dock-results.is-flat {
    padding-top: 1rem;
  }

  /*
   * These are built at runtime via document.createElement/innerHTML in the
   * <script> below, so they never get Astro's scoped data-astro-cid
   * attribute — scoped rules would silently not match them. Use :global()
   * so they apply regardless.
   */
  :global(.dock-group) {
    margin-bottom: 1.5rem;
  }

  :global(.dock-group:last-child) {
    margin-bottom: 0;
  }

  :global(.dock-group-title) {
    position: sticky;
    top: 0;
    z-index: 2;
    margin: 0 -0.75rem 0.6rem;
    padding: 0.4rem 0.75rem;
    border: none;
    border-bottom: 1px solid var(--border-muted);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-light);
    font-weight: 700;
    background: var(--bg-translucent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  :global(.dock-result-link) {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.45rem 0.5rem;
    border-radius: 6px;
    transition: var(--transition);
  }

  :global(.dock-result-link:hover) {
    background: var(--bg-soft);
    text-decoration: none;
  }

  :global(.dock-result-link:active) {
    background: var(--accent-bg);
    transform: scale(0.98);
  }

  :global(.dock-result-title) {
    color: var(--text);
    font-weight: 600;
    font-size: 0.875rem;
  }

  :global(.dock-result-desc) {
    color: var(--text-light);
    font-size: 0.8rem;
  }

  .dock-empty {
    padding: 1rem;
    text-align: center;
    color: var(--text-light);
    font-size: 0.875rem;
  }

  .dock-bar {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem;
    background: var(--bg-translucent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: 999px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }

  .dock-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .dock-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 50%;
    border: none;
    background: none;
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition);
  }

  .dock-icon-btn:hover {
    background: var(--bg-soft);
    color: var(--text);
  }

  .dock-icon-btn.active {
    color: var(--accent);
  }

  .dock-logo-img {
    height: 24px;
    width: 24px;
    border: none;
    border-radius: 6px;
  }

  [data-role="expanded"] {
    display: none;
  }

  .dock[data-expanded="true"] .dock-bar [data-role="collapsed"] {
    display: none;
  }

  .dock[data-expanded="true"] .dock-bar [data-role="expanded"] {
    display: flex;
  }

  .dock-input {
    display: none;
    flex: 1;
    min-width: 0;
    border: none;
    background: none;
    outline: none;
    font: inherit;
    color: var(--text);
    padding: 0 0.5rem;
  }

  .dock[data-expanded="true"] .dock-input {
    display: block;
  }

  .dock-input::placeholder {
    color: var(--text-light);
  }
</style>
