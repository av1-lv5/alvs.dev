---
import { Icon } from "astro-icon/components";

interface Props {
  name: string;
  host: string;
  artworkUrl: string;
  description: string;
  feedUrl: string;
  appleUrl: string;
  spotifyUrl?: string;
  website?: string;
  youtube?: string;
}

const {
  name,
  host,
  artworkUrl,
  feedUrl,
  appleUrl,
  spotifyUrl,
  website,
  youtube,
} = Astro.props;
---

<div class="podcast-card">
  {
    artworkUrl ? (
      <img src={artworkUrl} alt={name} loading="lazy" class="thumb" />
    ) : (
      <div class="thumb placeholder" aria-hidden="true" />
    )
  }

  <div class="info">
    <span class="title">{name}</span>
  </div>

  <div class="icon-links">
    {
      youtube && (
        <a
          href={youtube}
          target="_blank"
          rel="noopener noreferrer"
          title="YouTube"
        >
          <Icon name="simple-icons:youtube" size={15} />
        </a>
      )
    }
    {
      spotifyUrl && (
        <a
          href={spotifyUrl}
          target="_blank"
          rel="noopener noreferrer"
          title="Spotify"
        >
          <Icon name="simple-icons:spotify" size={15} />
        </a>
      )
    }
    <a
      href={appleUrl}
      target="_blank"
      rel="noopener noreferrer"
      title="Apple Podcasts"
    >
      <Icon name="simple-icons:applepodcasts" size={15} />
    </a>
    {
      website && (
        <a
          href={website}
          target="_blank"
          rel="noopener noreferrer"
          title="Website"
        >
          <Icon name="lucide:globe" size={15} />
        </a>
      )
    }
    <a href={feedUrl} target="_blank" rel="noopener noreferrer" title="RSS">
      <Icon name="lucide:rss" size={15} />
    </a>
  </div>
</div>

<style>
  .podcast-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius);
    transition: var(--transition);
  }

  .podcast-card:hover {
    border-color: var(--accent);
    background: var(--accent-bg);
  }

  .thumb {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: inset 0 0 0 1px var(--border);
  }

  .placeholder {
    background: var(--accent-bg);
  }

  .info {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    overflow: hidden;
  }

  .title {
    flex: 2 1 0%;
    min-width: 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dot {
    flex-shrink: 0;
    font-size: 0.8rem;
    color: var(--text-light);
    font-family: var(--mono);
  }

  .host {
    flex: 1 1 0%;
    min-width: 0;
    font-size: 0.8rem;
    color: var(--text-light);
    font-family: var(--mono);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .icon-links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
    color: var(--text-light);
  }

  .icon-links a {
    display: flex;
    color: inherit;
    transition: var(--transition);
  }

  .icon-links a:hover {
    color: var(--accent);
  }

  @media (pointer: coarse) {
    .icon-links {
      gap: 0.25rem;
    }

    .icon-links a {
      padding: 0.5rem;
      margin: -0.5rem;
    }
  }

  @media (max-width: 480px) {
    .podcast-card {
      flex-wrap: wrap;
    }

    .icon-links {
      flex-basis: 100%;
      justify-content: flex-end;
      gap: 0.9rem;
      margin-top: 0.375rem;
    }
  }
</style>
