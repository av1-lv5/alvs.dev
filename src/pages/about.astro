---
// layout
import PageLayout from "@layouts/PageLayout.astro";
import { getGeneratedOgImage } from "@utils/og-image";

const ogImage = getGeneratedOgImage("pages", "about");
---

<PageLayout
  tabTitle="About"
  description="More context. Fewer buzzwords."
  image={ogImage}
>
  <section class="hero">
    <h1>A bit about me</h1>
    <div>
      <p class="hero-text">
        I do web development for fun and as a profession too. I spend most hours
        of the day in the corners of the web not knowing how I ended up there.
      </p>
      <p class="hero-text">
        I love <a href="/music">music</a>, you couldn't find me sitting idle,
        something is always playing. That same restlessness spills into{" "}
        <a href="/movies">movies</a> too, at least three hours of my week disappear
        into watching a movie and if there's a plan for a cinema, always count me
        in.
      </p>
      <p class="hero-text">
        Then there are the random rides I go off to. You could find me just
        casually taking my bike out for a spin, the beat of the engine and a
        favorite song on repeat somehow makes everything feel under control for
        a while. Cheapest therapy I've found.
      </p>
    </div>
  </section>

  <section id="random-bits">
    <h2>Random bits</h2>
    <div class="bits-grid">
      <div class="bit-card card">
        <p>Prefers chai over coffee (green tea is overrated)</p>
      </div>

      <div class="bit-card card">
        <p>Team Android, always</p>
      </div>
      <div class="bit-card card">
        <p>Main colors: black, white, blue, and gray</p>
      </div>
      <div class="bit-card card">
        <p>
          Types at{" "}
          <a target="_blank" href="https://monkeytype.com/profile/av-sh">
            70wpm &#x2197;
          </a>{" "}
          <small>(best: 83wpm)</small>
        </p>
      </div>
      <div class="bit-card card wide">
        <p>Advocate for 'shipping over polishing forever'</p>
      </div>
    </div>
    <script
      is:inline
      src="https://keepandroidopen.org/banner.js?link=https://keepandroidopen.org/&hidebutton=off&id=random-bits"
    ></script>
  </section>

  <section>
    <h2>Discovery</h2>
    <div class="discovery-grid">
      <div class="discovery-item">
        <h3>Writing & Reading</h3>
        <p>
          I keep a collection of <a href="/notes">public notes</a> on things I want
          to share, and a list of <a href="/books">books</a> I've read.
        </p>
      </div>
      <div class="discovery-item">
        <h3>Backstage</h3>
        <p>
          Curious about the <a href="/uses">gear and software</a> I use daily? Or
          maybe the <a href="/feeds">RSS feeds</a> I follow to stay updated.
        </p>
      </div>
      <div class="discovery-item">
        <h3>Social</h3>
        <p>
          Feel free to leave a message in my{" "}
          <a href="/guestbook">guestbook</a>. It's like a digital version of a
          coffee shop wall.
        </p>
      </div>
    </div>
  </section>

  <p class="closing-note">
    Its really hard to describe one-self. And once someone actually meets me,
    they form their own opinion anyway. So, as everyone else I'm still figuring
    myself out here, evolving big time, and honestly enjoying the journey.
  </p>
</PageLayout>

<style>
  .closing-note {
    font-size: 0.9rem;
    color: var(--text-light);
  }

  .bits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .bit-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .bit-card p {
    font-size: 0.95rem;
    margin: 0;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .bit-card.wide {
    grid-column: span 2;
  }

  .discovery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .discovery-item h3 {
    font-size: 1rem;
    margin-top: 0;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .discovery-item p {
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .bit-card.wide {
      grid-column: span 1;
    }

    .bits-grid {
      grid-template-columns: 1fr;
    }

    .discovery-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
