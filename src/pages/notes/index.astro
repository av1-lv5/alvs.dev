---
import { getCollection } from "astro:content";

// layout
import PageLayout from "@layouts/PageLayout.astro";

// fetching notes to display
const allNotes = (await getCollection("notes", ({ data }) => {
  return !data.draft;
})).sort((a, b) => {
  const dateA = a.data.publishedAt ?? "";
  const dateB = b.data.publishedAt ?? "";
  return dateB.localeCompare(dateA);
});
---

<PageLayout
  tabTitle="Notes"
  description="Unfiltered thoughts. Updated as evolves"
>
  <section class="hero">
    <h1>My public notes</h1>
    <p class="hero-text">
      The content in my notes gets often updated to my current opinions. Notes
      may be unfinished, unpolished. I write to record my thoughts, ideas and
      opinions.
    </p>
    <ul>
      {
        allNotes.map((note) => {
          return (
            <li>
              <a href={`/notes/${note.id}`}>{note.data.title}</a>
              {note.data.updatedAt && (
                <span class="updated-at">Updated {note.data.updatedAt}</span>
              )}
            </li>
          );
        })
      }
    </ul>
  </section>
</PageLayout>

<style>
  ul {
    list-style: none;
    padding-left: 0;
  }
  li {
    display: flex;
    padding-left: 0;
    align-items: baseline;
  }
  .updated-at {
    font-size: 0.7rem;
    opacity: 0.4;
    flex-shrink: 0;
    margin-left: 1rem;
  }
</style>
