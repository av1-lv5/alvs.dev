---
// layout
import PageLayout from "@layouts/PageLayout.astro";
// data
import { sitemapSections } from "@data/sitemap";
---

<PageLayout
  tabTitle="Sitemap"
  description="Every page on this site, organized."
>
  <section>
    <h1>/sitemap</h1>
    <p class="hero-text">A full map of every page on this site.</p>
  </section>

  {
    sitemapSections.map((section) => (
      <section>
        <h2>{section.title}</h2>
        <ul class="sitemap-list">
          {section.items.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a> - {item.description}
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</PageLayout>

<style>
  .sitemap-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sitemap-list li {
    color: var(--text-muted);
  }

  .sitemap-list a {
    color: var(--text);
    font-weight: 500;
    transition: var(--transition);
  }

  .sitemap-list a:hover {
    color: var(--text-muted);
  }
</style>
