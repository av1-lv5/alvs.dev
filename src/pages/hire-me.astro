---
// layout
import PageLayout from "@layouts/PageLayout.astro";

// Components
import Skills from "@components/Skills.astro";
import Experiences from "@components/Experiences.astro";
import ProjectsList from "@components/ProjectsList.astro";
import GithubCommitGraph from "@components/GithubCommitGraph.astro";
import { socials } from "@constants/index";
import { Icon } from "astro-icon/components";
import Tooltip from "@components/Tooltip.astro";
---

<PageLayout
  tabTitle="Hire Avi"
  description="Frontend developer available for freelance, contract, or full-time work."
>
  <section>
    <h1>Hire me</h1>
    <p class="hero-text">
      I'm Avinash, a frontend engineer with 2+ years of experience shipping
      production-grade web applications professionally and 4+ years of building
      for the web in total.
    </p>
    <p class="hero-text">
      My core stack centers on Next.js, TypeScript, and Tailwind CSS. I've
      shipped real estate platforms, budgeting tools in production. I can reach
      into backend and infrastructure when the project needs it.
    </p>
    <p class="hero-text">
      <strong>Currently available</strong> for freelance, contract, or full-time work.
    </p>
  </section>

  <section>
    <h2>Experience</h2>
    <Experiences count={2} />
  </section>

  <section>
    <h2>Core stack</h2>
    <Skills />
    <blockquote class="skills-note">
      For a comprehensive breakdown, check out
      <a href="/notes/skills-and-tools">
        my public note on skills and tools
      </a>.
    </blockquote>
  </section>

  <section>
    <h2>Projects</h2>
    <ProjectsList count={4} />
  </section>

  <section>
    <h2>Activity</h2>
    <GithubCommitGraph />
  </section>

  <section>
    <h2>Contact</h2>
    <p>
      If you have a role or project that seems like a fit, email is the best way
      to reach me. I reply within 24-48 hours.
    </p>
    <div class="contact-links">
      <Tooltip text="Click to copy">
        <button
          class="copy-email-btn"
          data-email={socials.email}
          data-success="Half the hiring process, done"
        >
          <Icon name="lucide:copy" size={14} class="icon-copy" />
          <Icon name="lucide:check" size={14} class="icon-check" />
          Send an email
        </button>
      </Tooltip>
      <span class="sep">·</span>
      <a
        href="https://docs.google.com/document/d/18bA86UaDA-uf2K0nV5dYiv23MMp_YkEjvkvXBcwXH6M/export?format=pdf"
      >
        <Icon name="lucide:download" />
        Resume
      </a>
      <span class="sep">·</span>
      <a href={socials.linkedin} target="_blank" rel="noopener noreferrer">
        <Icon name="lucide:linkedin" />
        LinkedIn
      </a>
      <span class="sep">·</span>
      <a
        href={`https://github.com/${socials.githubUsername}`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon name="lucide:github" />
        GitHub
      </a>
    </div>
  </section>
</PageLayout>

<script>
  const btn = document.querySelector<HTMLButtonElement>(".copy-email-btn")!;
  let timeout: ReturnType<typeof setTimeout> | null = null;

  btn.addEventListener("click", async () => {
    const email = btn.dataset.email!;
    const successMsg = btn.dataset.success!;
    const wrapper = btn.closest<HTMLElement>(".tooltip-wrapper")!;
    const tooltip = wrapper.querySelector<HTMLElement>(".tooltip-text")!;

    await navigator.clipboard.writeText(email);

    if (timeout) clearTimeout(timeout);

    btn.classList.add("copied");
    wrapper.classList.add("show-tooltip", "tooltip-success");
    tooltip.textContent = successMsg;

    timeout = setTimeout(() => {
      btn.classList.remove("copied");
      wrapper.classList.remove("show-tooltip", "tooltip-success");
      tooltip.textContent = "Click to copy";
      timeout = null;
    }, 2000);
  });
</script>

<style>
  .skills-note {
    margin: 1.5rem 0 0 0;
    font-size: 0.9rem;
  }

  .contact-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.95rem;
  }

  .contact-links a,
  .copy-email-btn {
    all: unset;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    font: inherit;
    font-size: inherit;
    transition: var(--transition);
  }

  .contact-links a:hover,
  .copy-email-btn:hover {
    color: var(--text);
  }

  .contact-links svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .icon-copy {
    color: var(--text-muted);
  }

  .icon-check {
    display: none;
    color: #10b981;
  }

  .copy-email-btn.copied .icon-copy {
    display: none;
  }

  .copy-email-btn.copied .icon-check {
    display: block;
  }

  .sep {
    color: var(--text-muted);
    font-size: 1.2rem;
    user-select: none;
  }
</style>
